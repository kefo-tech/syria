<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>مواقيت الصلاة | KeFo.tech</title>
  <meta name="description" content="مواقيت الصلاة اليومية بتصميم إسلامي أنيق مع دعم تعدد اللغات والكشف التلقائي للغة المستخدم." />
  <style>
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    :root{
      --bg1:#0f2f23;
      --bg2:#153d2d;
      --gold:#d4af37;
      --gold-soft:#e7c866;
      --cream:#f7f2e7;
      --line:rgba(212,175,55,.22);
      --text:#183126;
      --muted:#5f6f66;
      --white:#ffffff;
      --shadow:0 14px 45px rgba(0,0,0,.22);
    }

    html, body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      user-select: none;
      -webkit-user-select: none;
      -webkit-touch-callout: none;
    }

    body{
      font-family: Tahoma, Arial, sans-serif;
      background:
        radial-gradient(circle at top right, rgba(212,175,55,.12), transparent 28%),
        radial-gradient(circle at top left, rgba(255,255,255,.05), transparent 22%),
        linear-gradient(160deg, var(--bg1), #0b2119 52%, var(--bg2));
      color: var(--white);
      overflow-x: hidden;
    }

    .wrap{
      width:min(100%, 820px);
      margin:0 auto;
      padding:28px 14px 18px;
    }

    .hero{
      text-align:center;
      padding:10px 8px 18px;
    }

    .hero .mini{
      color:var(--gold-soft);
      font-size:14px;
      letter-spacing:.5px;
      margin-bottom:10px;
    }

    .hero h1{
      margin:0;
      font-size:34px;
      line-height:1.2;
      color:#fff7dc;
      text-shadow:0 2px 14px rgba(0,0,0,.18);
    }

    .hero p{
      margin:10px auto 0;
      max-width:620px;
      color:#dfe8e2;
      font-size:15px;
      line-height:1.8;
    }

    .card{
      background:linear-gradient(180deg, rgba(255,248,233,.98), rgba(248,244,235,.98));
      color:var(--text);
      border:1px solid rgba(212,175,55,.22);
      border-radius:28px;
      overflow:hidden;
      box-shadow:var(--shadow);
      backdrop-filter: blur(10px);
      position:relative;
    }

    .card::before{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:
        radial-gradient(circle at top left, rgba(212,175,55,.10), transparent 22%),
        radial-gradient(circle at bottom right, rgba(21,61,45,.06), transparent 26%);
    }

    .top{
      padding:22px 18px 18px;
      border-bottom:1px solid var(--line);
      position:relative;
      z-index:1;
    }

    .search-title{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:14px;
      color:#244635;
      font-size:22px;
      font-weight:700;
    }

    .search-title .dot{
      width:10px;
      height:10px;
      border-radius:50%;
      background:var(--gold);
      box-shadow:0 0 0 6px rgba(212,175,55,.15);
    }

    .controls{
      display:flex;
      gap:10px;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
      margin-bottom:12px;
    }

    .lang-badge{
      background:rgba(212,175,55,.14);
      color:#234736;
      border:1px solid rgba(212,175,55,.25);
      padding:8px 12px;
      border-radius:999px;
      font-size:13px;
      font-weight:700;
    }

    .search-box{
      display:grid;
      grid-template-columns: 1fr auto;
      gap:10px;
    }

    .search-box input{
      width:100%;
      border:1px solid rgba(21,61,45,.12);
      background:#fffdf8;
      color:#173126;
      border-radius:16px;
      padding:15px 16px;
      font-size:17px;
      outline:none;
      transition:.2s;
    }

    .search-box input:focus{
      border-color:rgba(212,175,55,.7);
      box-shadow:0 0 0 4px rgba(212,175,55,.12);
    }

    .search-box button{
      border:none;
      border-radius:16px;
      padding:0 22px;
      min-width:125px;
      font-size:16px;
      font-weight:700;
      cursor:pointer;
      background:linear-gradient(135deg, #c8a12f, #e5c15a);
      color:#173126;
      box-shadow:0 8px 20px rgba(212,175,55,.25);
      transition:.2s ease;
    }

    .search-box button:hover{
      transform:translateY(-1px);
    }

    .meta{
      padding:18px 18px 10px;
      color:#4b5f54;
      font-size:18px;
      font-weight:600;
      position:relative;
      z-index:1;
    }

    .next-prayer{
      padding:10px 18px 20px;
      border-bottom:1px solid var(--line);
      position:relative;
      z-index:1;
    }

    .next-prayer small{
      display:block;
      color:#617369;
      font-size:16px;
      margin-bottom:10px;
      line-height:1.8;
    }

    .big-time{
      font-size:58px;
      line-height:1;
      font-weight:800;
      color:#183126;
      letter-spacing:1px;
      direction:ltr;
      text-align:right;
    }

    .table{
      position:relative;
      z-index:1;
    }

    .row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:22px 18px;
      border-bottom:1px solid var(--line);
      font-size:20px;
    }

    .row:last-child{
      border-bottom:none;
    }

    .label{
      font-weight:700;
      color:#234736;
    }

    .time{
      direction:ltr;
      font-weight:800;
      color:#10271d;
      font-size:21px;
    }

    .status{
      padding:16px 18px 20px;
      color:#63756b;
      font-size:15px;
      line-height:1.8;
      position:relative;
      z-index:1;
    }

    .status.error{
      color:#9f1d1d;
      font-weight:700;
    }

    .status.loading{
      color:#8a6b11;
      font-weight:700;
    }

    .footer{
      text-align:center;
      color:#dce6df;
      font-size:13px;
      margin-top:16px;
      line-height:1.9;
      padding:0 10px 12px;
    }

    .footer b{
      color:#f3d980;
      font-weight:700;
    }

    .notice{
      text-align:center;
      margin-top:10px;
      color:#e9d8a0;
      font-size:12px;
      opacity:.9;
    }

    @media (max-width:640px){
      .wrap{ padding:18px 10px 14px; }
      .hero h1{ font-size:28px; }
      .search-box{ grid-template-columns:1fr; }
      .search-box button{
        min-height:52px;
        width:100%;
      }
      .big-time{ font-size:44px; }
      .row{ font-size:18px; }
      .time{ font-size:19px; }
      .meta{ font-size:16px; }
    }
  </style>
</head>
