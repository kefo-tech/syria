      document.getElementById("labelDhuhr").textContent = t.dhuhr;
      document.getElementById("labelAsr").textContent = t.asr;
      document.getElementById("labelMaghrib").textContent = t.maghrib;
      document.getElementById("labelIsha").textContent = t.isha;

      document.getElementById("footerText").innerHTML = t.footer;
      document.getElementById("noticeText").textContent = t.notice;

      if (!statusBox.dataset.locked) {
        statusBox.textContent = t.statusIdle;
      }
    }

    function setStatus(message, type = "") {
      statusBox.className = "status";
      if (type === "error") statusBox.classList.add("error");
      if (type === "loading") statusBox.classList.add("loading");
      statusBox.textContent = message;
      statusBox.dataset.locked = "1";
    }

    function setIdleStatus() {
      statusBox.className = "status";
      statusBox.textContent = t.statusIdle;
      delete statusBox.dataset.locked;
    }

    function cleanTime(value) {
      return String(value).split(" ")[0].replace(/\(.+\)/, "").trim();
    }

    function toMinutes(hhmm) {
      const [h, m] = hhmm.split(":").map(Number);
      return h * 60 + m;
    }

    function getNextPrayer(timings) {
      const now = new Date();
      const currentMinutes = now.getHours() * 60 + now.getMinutes();

      const prayers = [
        { name: t.fajr, time: timings.Fajr },
        { name: t.dhuhr, time: timings.Dhuhr },
        { name: t.asr, time: timings.Asr },
        { name: t.maghrib, time: timings.Maghrib },
        { name: t.isha, time: timings.Isha }
      ];

      for (const prayer of prayers) {
        if (toMinutes(prayer.time) > currentMinutes) {
          return prayer;
        }
      }

      return { name: t.nextPrayerTomorrow, time: timings.Fajr };
    }

    async function geocodeCity(city) {
      const url = `https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=${encodeURIComponent(city)}`;
      const response = await fetch(url, {
        headers: { "Accept": "application/json" }
      });

      if (!response.ok) {
        throw new Error(t.geoError);
      }

      const results = await response.json();
      if (!results || !results.length) {
        throw new Error(t.notFound);
      }

      const place = results[0];
      return {
        lat: place.lat,
        lon: place.lon,
        displayName: place.display_name
      };
    }

    async function fetchPrayerTimesByCoords(lat, lon) {
      const now = new Date();
      const day = now.getDate();
      const month = now.getMonth() + 1;
      const year = now.getFullYear();

      const url = `https://api.aladhan.com/v1/timings/${day}-${month}-${year}?latitude=${encodeURIComponent(lat)}&longitude=${encodeURIComponent(lon)}&method=4`;

      const response = await fetch(url);
      if (!response.ok) {
        throw new Error(t.fetchError);
      }

      const data = await response.json();
      if (!data || data.code !== 200 || !data.data) {
        throw new Error(t.fetchError);
      }

      return data.data;
    }

    async function runSearch() {
      const city = cityInput.value.trim();

      if (!city) {
        setStatus(t.statusEmpty, "error");
        prayerTable.style.display = "none";
        nextPrayerBox.style.display = "none";
        metaText.textContent = "—";
        return;
      }

      setStatus(t.statusLoading, "loading");
      prayerTable.style.display = "none";
      nextPrayerBox.style.display = "none";
      metaText.textContent = "—";

      try {
        const geo = await geocodeCity(city);
        const prayerData = await fetchPrayerTimesByCoords(geo.lat, geo.lon);

        const timings = prayerData.timings;
        const dateReadable = prayerData.date?.readable || "";
        const hijriDate = prayerData.date?.hijri?.date || "";
        const timezone = prayerData.meta?.timezone || "";

        const fajr = cleanTime(timings.Fajr);
        const sunrise = cleanTime(timings.Sunrise);
        const dhuhr = cleanTime(timings.Dhuhr);
        const asr = cleanTime(timings.Asr);
        const maghrib = cleanTime(timings.Maghrib);
        const isha = cleanTime(timings.Isha);

        fajrEl.textContent = fajr;
        sunriseEl.textContent = sunrise;
        dhuhrEl.textContent = dhuhr;
        asrEl.textContent = asr;
        maghribEl.textContent = maghrib;
        ishaEl.textContent = isha;

        metaText.textContent = `${geo.displayName} — ${dateReadable}${timezone ? " — " + timezone : ""}`;

        const next = getNextPrayer({
          Fajr: fajr,
          Dhuhr: dhuhr,
          Asr: asr,
          Maghrib: maghrib,
          Isha: isha
        });

        nextPrayerLabel.textContent = `${t.nextPrayer} ${next.name}`;
        nextPrayerTime.textContent = next.time;

        prayerTable.style.display = "block";
        nextPrayerBox.style.display = "block";

        let successText = t.statusSuccess;
        if (hijriDate) successText += ` — ${t.hijriDate}: ${hijriDate}`;
        setStatus(successText);
      } catch (error) {
        console.error(error);
        setStatus(error.message || t.genericError, "error");
        prayerTable.style.display = "none";
        nextPrayerBox.style.display = "none";
        metaText.textContent = "—";
      }
    }

    searchBtn.addEventListener("click", runSearch);

    cityInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") runSearch();
    });

    applyLanguage();

    document.addEventListener("contextmenu", function(e) {
      e.preventDefault();
    });

    document.addEventListener("dragstart", function(e) {
      e.preventDefault();
    });

    document.addEventListener("selectstart", function(e) {
      e.preventDefault();
    });

    document.addEventListener("copy", function(e) {
      e.preventDefault();
    });

    document.addEventListener("cut", function(e) {
      e.preventDefault();
    });

    document.addEventListener("keydown", function(e) {
      const key = e.key.toLowerCase();

      if (e.key === "F12") {
        e.preventDefault();
        return false;
      }

      if (e.ctrlKey && e.shiftKey && ["i", "j", "c"].includes(key)) {
        e.preventDefault();
        return false;
      }

      if (e.ctrlKey && ["u", "s", "p", "c", "x"].includes(key)) {
        e.preventDefault();
        return false;
      }
    });

    let devtoolsOpen = false;
    setInterval(function () {
      const widthThreshold = window.outerWidth - window.innerWidth > 160;
      const heightThreshold = window.outerHeight - window.innerHeight > 160;
      if (widthThreshold || heightThreshold) {
        if (!devtoolsOpen) {
          devtoolsOpen = true;
          document.body.innerHTML = `
            <div style="
              min-height:100vh;
              display:flex;
              align-items:center;
              justify-content:center;
              text-align:center;
              padding:30px;
              background:linear-gradient(160deg,#0f2f23,#153d2d);
              color:#fff7dc;
              font-family:Tahoma,Arial,sans-serif;
              direction:${t.dir};
            ">
              <div>
                <div style="font-size:32px;font-weight:800;margin-bottom:12px;">${t.title}</div>
                <div style="font-size:18px;line-height:1.9;">${t.notice}</div>
              </div>
            </div>
          `;
        }
      } else {
        devtoolsOpen = false;
      }
    }, 1000);
  </script>
</body>
</html>
